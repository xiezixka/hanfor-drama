{
  "name": "hanfor-ai-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "涵锋AI桌面安装包",
  "main": "desktop/main.cjs",
  "scripts": {
    "desktop:prepare": "node desktop/scripts/prepare-app.mjs",
    "desktop:rebuild-native": "electron-rebuild -f --module-dir backend",
    "desktop:dev": "npm run desktop:prepare && electron .",
    "dist:mac": "npm run desktop:prepare && npm run desktop:rebuild-native && node desktop/scripts/build-mac.mjs",
    "dist:win": "npm run desktop:prepare && npm run desktop:rebuild-native && electron-builder --win nsis --publish never",
    "dist:win:portable": "npm run desktop:prepare && npm run desktop:rebuild-native && electron-builder --win portable --publish never"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.hanfor.ai",
    "productName": "涵锋AI",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules"
      },
      {
        "from": "frontend/.output/public",
        "to": "frontend/dist"
      },
      {
        "from": "skills",
        "to": "skills"
      },
      {
        "from": "build/icon.png",
        "to": "assets/app-icon.png"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "title": "涵锋AI ${version}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "涵锋AI"
    }
  }
}
